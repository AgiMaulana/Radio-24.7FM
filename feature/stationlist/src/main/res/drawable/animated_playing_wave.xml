<?xml version="1.0" encoding="utf-8"?>
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/ic_playing_wave">

    <target android:name="group_bar1">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="scaleY"
                android:valueFrom="1.0" android:valueTo="0.2"
                android:duration="800" android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate"/>
        </aapt:attr>
    </target>
    <target android:name="group_bar2">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="scaleY"
                android:valueFrom="0.5" android:valueTo="1.0"
                android:duration="600" android:startOffset="150"
                android:repeatCount="infinite" android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate"/>
        </aapt:attr>
    </target>
    <target android:name="group_bar3">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="scaleY"
                android:valueFrom="1.0" android:valueTo="0.15"
                android:duration="700" android:startOffset="80"
                android:repeatCount="infinite" android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate"/>
        </aapt:attr>
    </target>
    <target android:name="group_bar4">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="scaleY"
                android:valueFrom="0.4" android:valueTo="1.0"
                android:duration="650" android:startOffset="250"
                android:repeatCount="infinite" android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate"/>
        </aapt:attr>
    </target>
    <target android:name="group_bar5">
        <aapt:attr name="android:animation">
            <objectAnimator android:propertyName="scaleY"
                android:valueFrom="1.0" android:valueTo="0.25"
                android:duration="850" android:startOffset="50"
                android:repeatCount="infinite" android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate"/>
        </aapt:attr>
    </target>

</animated-vector>
