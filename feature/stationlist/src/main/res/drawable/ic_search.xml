<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_search.xml
    Place in res/drawable/

    A clean search icon with a slightly thicker stroke to feel bold
    and match the app's design weight. Uses your primary pink as tint.

    Usage in XML:
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:tint="@color/primary" />

    Usage in Compose:
        Icon(
            painter = painterResource(R.drawable.ic_search),
            contentDescription = "Search",
            tint = MaterialTheme.colorScheme.primary,
            modifier = Modifier.size(20.dp)
        )

    The icon is drawn at 24x24 viewport so it scales cleanly to any dp size.
    Recommended sizes: 18dp (dense), 20dp (default), 24dp (prominent).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Search circle -->
    <path
        android:pathData="M10.5,3 A7.5,7.5 0 1,1 10.499,3 Z"
        android:fillColor="#00000000"
        android:strokeColor="#FF69B4"
        android:strokeWidth="2"
        android:strokeLineCap="round"/>

    <!-- Search handle -->
    <path
        android:pathData="M16.5,16.5 L21,21"
        android:fillColor="#00000000"
        android:strokeColor="#FF69B4"
        android:strokeWidth="2"
        android:strokeLineCap="round"/>

</vector>